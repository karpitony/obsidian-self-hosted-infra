# [CouchDB Configuration]
COUCHDB_USER=admin
COUCHDB_PASSWORD=your_secure_password
COUCHDB_URL=http://localhost:5984

# [Google Drive Backup]
GDRIVE_FOLDER_ID=your_google_drive_folder_id_here

# [System]
OBSIDIAN_VAULT_PATH=./vault

# [Notifications]
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
ALLOWED_USER_ID=

# 구글 콘솔에 등록된 리디렉션 URI (반드시 127.0.0.1 고정)
GDRIVE_REDIRECT_URI=http://127.0.0.1:8080/

# 실제 서버의 테일스케일 IP 및 포트
SERVER_IP=your_server_ip_or_domain
SERVER_PORT=8080